+                        0,
+                        self.ordered_bits - 1 * self.radix_bits,
+                        shared_ordered,
+                        actual_chunk_size,
+                        prefix,
+                        remaining_k,
+                        local_histogram,
+                        prefix_buf,
+                        s_scalars,
+                        s_warp_sums,
+                        num_threads,
+                        tidx,
+                    )
+                    # Round 1
+                    prefix, remaining_k = self._radix_round_single_cta(
+                        1,
+                        self.ordered_bits - 2 * self.radix_bits,
+                        shared_ordered,
+                        actual_chunk_size,
+                        prefix,
+                        remaining_k,
+                        local_histogram,
+                        prefix_buf,
+                        s_scalars,
+                        s_warp_sums,
+                        num_threads,
+                        tidx,
