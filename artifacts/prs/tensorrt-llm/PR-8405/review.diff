+            self.gen_cached_token_indptr,
+            device='cpu',
+            pin_memory=True,
+        )
+        self.gen_kv_indptr = get_empty(
+            (self.max_num_requests + 1, ),
+            cache_name="gen_kv_indptr",
+            dtype=torch.int64,
+        )
