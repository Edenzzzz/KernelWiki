+            x.stride(0),
+            x.stride(1),
+            x.stride(2),
+            x.stride(3),
+            # C strides
+            C.stride(0),
+            C.stride(1),
+            C.stride(2),
+            C.stride(3),
+            # D strides
+            *(D.stride(0), D.stride(1)) if D is not None else (0, 0),
+            # z strides
+            z_strides[0],
