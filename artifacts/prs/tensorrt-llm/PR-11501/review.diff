+                                                                                                                       \
+    if (data.hiddenDim % (numCtasPerToken * finalizeElemPerThread) != 0)                                               \
+    {                                                                                                                  \
+        int optimalCtasPerToken = 1;                                                                                   \
+        for (int i = numCtasPerToken; i > 0; --i)                                                                      \
+        {                                                                                                              \
+            if (data.hiddenDim % (i * finalizeElemPerThread) == 0)                                                     \
+            {                                                                                                          \
+                optimalCtasPerToken = i;                                                                               \
