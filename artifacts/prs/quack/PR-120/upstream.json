    "title": "Fix ColVecReduce shared-memory staging",
    "user": {
      "login": "alecco",
      "id": 306450,
      "node_id": "MDQ6VXNlcjMwNjQ1MA==",
      "avatar_url": "https://avatars.githubusercontent.com/u/306450?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/alecco",
      "html_url": "https://github.com/alecco",
      "followers_url": "https://api.github.com/users/alecco/followers",
      "following_url": "https://api.github.com/users/alecco/following{/other_user}",
      "gists_url": "https://api.github.com/users/alecco/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/alecco/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/alecco/subscriptions",
      "organizations_url": "https://api.github.com/users/alecco/orgs",
      "repos_url": "https://api.github.com/users/alecco/repos",
      "events_url": "https://api.github.com/users/alecco/events{/privacy}",
      "received_events_url": "https://api.github.com/users/alecco/received_events",
      "type": "User",
