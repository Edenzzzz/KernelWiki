-    if constexpr (KernelParams::isPow2)
-    {
-        permutedIdxSize = mulLog2<int32_t>(numNonExitingCtas, params.mPaddingLog2);
-    }
-    else
-    {
-        permutedIdxSize = mulTileN<int32_t>(numNonExitingCtas, params.mTileTokensDim);
-    }
-
-    // write out padded count
