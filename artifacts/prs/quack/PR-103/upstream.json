      "followers_url": "https://api.github.com/users/thakkarV/followers",
      "following_url": "https://api.github.com/users/thakkarV/following{/other_user}",
      "gists_url": "https://api.github.com/users/thakkarV/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/thakkarV/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/thakkarV/subscriptions",
      "organizations_url": "https://api.github.com/users/thakkarV/orgs",
      "repos_url": "https://api.github.com/users/thakkarV/repos",
