+    :param use_cupti (bool, optional): If True, uses CUPTI to measure execution time.
+            Defaults to False.
+    """
+    m_aligned = mma_tiler_mn[0]
+    use_2cta_instrs = mma_tiler_mn[0] == 256 and cluster_shape_mn[0] % 2 == 0
+
