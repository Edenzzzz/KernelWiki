+                         dim=0,
+                         dtype=torch.int64,
+                         out=self.host_gen_kv_indptr[1:num_generations + 1])
+
+            # Add indexer-specific attributes
+            self.indexer_max_chunk_size = indexer_max_chunk_size
+            self.indexer_prefill_chunks = None
+
+    return MockMetadata()
