+    y_ref = gated_to_pytorch_fn_map[activation](*y_ref.chunk(2, dim=-1))
+    out_ref = F.linear(y_ref, w2_ref)
+    y_pt = F.linear(x_pt, w1_pt)
+    y_pt = gated_to_pytorch_fn_map[activation](*y_pt.chunk(2, dim=-1))
+    out_pt = F.linear(y_pt, w2_pt)
