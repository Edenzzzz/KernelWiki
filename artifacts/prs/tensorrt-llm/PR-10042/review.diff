+
+    # Initialize Stream
+    current_stream = cutlass_torch.default_stream()
+
+    # Compile gemm kernel
+    compiled_gemm = cute.compile(
+        gemm,
+        a_tensor,
+        b_tensor,
+        out_tensor,
+        sfa_tensor,
+        sfb_tensor,
+        tile_idx_to_expert_idx,
