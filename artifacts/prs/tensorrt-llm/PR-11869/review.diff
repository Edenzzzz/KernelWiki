+    qkv,
+    num_heads_q,
+    num_heads_k,
+    num_heads_v,
+    head_dim,
+    eps,
+    q_weight,
+    k_weight,
+    q_add_weight,
+    k_add_weight,
+    cos_emb,
+    sin_emb,
+    num_txt_tokens,
+    k_cos_emb,
+    k_sin_emb,
+    interleave,
+):
+    """Reference: per-head RMSNorm + RoPE (FLUX, Cosmos3)."""
+    num_tokens = qkv.shape[0]
+    q_size = num_heads_q * head_dim
+    k_size = num_heads_k * head_dim
