+            state,
+            old_x,
+            old_B,
+            old_dt,
+            old_dA_cumsum,
+            prev_num_accepted_tokens,
+            cache_buf_idx,
+            x,
+            C,
+            D,
+            z,
+            out,
+            cb_scaled,
+            decay_vec,
+            state_batch_indices,
+            rand_seed,
+            pad_slot_id,
+            T,
+            dim,
+            dstate,
+            nheads // ngroups,
+            # state strides
+            state.stride(0),
+            state.stride(1),
+            state.stride(2),
+            state.stride(3),
+            # old_x strides (single-buffered: cache, T, nheads, dim)
+            old_x.stride(0),
+            old_x.stride(1),
+            old_x.stride(2),
+            old_x.stride(3),
