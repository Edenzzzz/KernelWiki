+        layer_types = config.layer_types
+        num_layers = config.num_hidden_layers
+        dtype = config.torch_dtype
+        device = torch.device("cuda")
+
+        layers_info = []
+        for layer_idx in range(num_layers):
+            is_sliding = layer_types[layer_idx] == "sliding_attention"
+            hd = (
+                config.head_dim
