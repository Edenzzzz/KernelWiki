+            cb_scaled.stride(3),
+            # decay_vec strides
+            decay_vec.stride(0),
+            decay_vec.stride(1),
+            decay_vec.stride(2),
+            BLOCK_SIZE_M,
+            LAUNCH_WITH_PDL=use_internal_pdl,
+            PHILOX_ROUNDS=philox_rounds if rand_seed is not None else 0,
