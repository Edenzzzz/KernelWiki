+        a_tensor,
+        b_tensor,
+        sfa_tensor,
+        sfb_tensor,
+        alpha_scale_tensor,
+        alpha_scale_post_tensor,  # Post-SwiGLU alpha: (l, m, expert_count)
+        c_tensor,
