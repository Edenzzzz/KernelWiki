+    from tensorrt_llm._torch.auto_deploy.mlir.fx_to_mlir import FXToMLIRConverter
+    from tensorrt_llm._torch.auto_deploy.mlir.mlir_to_fx import MLIRToFXConverter
+
+    hidden = 128
