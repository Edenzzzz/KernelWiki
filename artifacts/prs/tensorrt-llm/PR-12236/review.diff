+                            self.ordered_bits - 3 * self.radix_bits,
+                            shared_ordered,
+                            actual_chunk_size,
+                            prefix,
+                            remaining_k,
+                            local_histogram,
+                            prefix_buf,
+                            s_scalars,
+                            s_warp_sums,
+                            num_threads,
+                            tidx,
+                        )
+                        # Round 3 (fp32 only)
