+            old_B.stride(0),
+            old_B.stride(1),
+            old_B.stride(2),
+            old_B.stride(3),
+            old_B.stride(4),
+            # old_dt strides
+            old_dt.stride(0),
+            old_dt.stride(1),
+            old_dt.stride(2),
+            old_dt.stride(3),
+            # old_dA_cumsum strides
+            old_dA_cumsum.stride(0),
