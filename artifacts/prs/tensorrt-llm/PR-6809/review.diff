+    //////////////////////////////////////////////////////////////////////////////////////////////////
+    //
+    // Miscellaneous parameters.
+    //
+    //////////////////////////////////////////////////////////////////////////////////////////////////
+
+    enum class MatrixType
+    {
+        MatrixA = 0,
+        MatrixB
+    };
+#endif
