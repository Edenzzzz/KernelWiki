+    base = tl.load(bt_ptr, mask=valid_block, other=0)
+
+    # If token == -1 OR block_id OOB, output -1
+    # Otherwise: base * stride_factor + inblock_off
+    # (stride_factor accounts for layer interleaving in strided KV cache pools)
