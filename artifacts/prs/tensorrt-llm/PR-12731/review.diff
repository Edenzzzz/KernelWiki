+)
+
+
+@dataclass
+class _MambaBlock:
+    block_type: str = "mamba"
+
+
+@dataclass
+class _MoeBlock:
+    block_type: str = "moe"
+    moe_intermediate_size: int = 1280
+    n_routed_experts: int = 512
+    num_experts_per_tok: int = 4
+    moe_latent_size: int = 1024
+    moe_shared_expert_intermediate_size: int = 5376
