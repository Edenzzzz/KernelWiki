-class MegaMoEDeepGemmFusedMoE(MoE):
-    """MoE backend wrapping DeepGEMM's fused ``fp8_fp4_mega_moe`` kernel."""
-
-    _SUPPORTED_ACTIVATION_DTYPES = frozenset({torch.bfloat16})
