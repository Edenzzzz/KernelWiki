+                        next_q_idx = q_idx + 1
+                        next_kv_idx = 0
+                        if next_q_idx < batch_size:
+                            next_num_kv = (
+                                mContextLens[next_q_idx] + block_kv_val - 1
+                            ) // block_kv_val
