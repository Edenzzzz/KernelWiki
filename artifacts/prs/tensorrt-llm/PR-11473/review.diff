+def fused_gated_rmsnorm_quant_available():
+    """Check if the fused_gated_rmsnorm_quant op is available."""
+    return hasattr(torch.ops, "trtllm") and hasattr(torch.ops.trtllm, "fused_gated_rmsnorm_quant")
