+            static int32_t const sm_count = tensorrt_llm::common::getMultiProcessorCount();
+            int32_t const max_blocks_per_sm
+                = tensorrt_llm::common::getMaxActiveBlocksPerSM(fn, ACTIVATION_THREADS_PER_BLOCK, 0);
