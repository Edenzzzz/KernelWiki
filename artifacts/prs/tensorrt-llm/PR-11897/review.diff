+    class CuteDSLNVFP4SwigluBlackwellRunner(TunableRunner):
+        """Runner for dense GEMM + SwiGLU fusion on Blackwell GPUs using CuteDSL.
+
+        Fuses the FC1 (gate_up projection) GEMM and SwiGLU activation into a
