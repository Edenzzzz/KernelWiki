+
+    # Calculate actual tensor_m used (with padding if permuted_m provided)
+    tensor_m = permuted_m if permuted_m is not None else valid_m
+
+    (
+        permuted_idx_to_expanded_idx_torch,
+        token_final_scales_torch,
