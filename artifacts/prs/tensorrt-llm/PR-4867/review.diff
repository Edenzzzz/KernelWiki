+                                               tp_rank=module.tp_rank,
+                                               tp_mode=module.tp_mode)
+        weight_scale = torch.cat(weight_scale, 0)
+        weight_scale = torch.ops.tensorrt_llm.nvfp4_block_scale_interleave(
+            weight_scale)
+        copy_weight(module.weight_scale, weight_scale)
