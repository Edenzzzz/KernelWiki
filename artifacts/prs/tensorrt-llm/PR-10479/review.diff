+    print(f"Use prefetch: {'True' if use_prefetch else 'False'}")
+    print(f"Prefetch dist: {prefetch_dist}")
+    print(f"Vectorized f32: {'True' if vectorized_f32 else 'False'}")
+    print(f"Tolerance: {tolerance}")
