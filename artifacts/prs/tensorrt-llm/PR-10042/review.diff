+
+    # Unpack parameters
+    n, k, l = nkl  # noqa: E741
+
+    if not torch.cuda.is_available():
+        raise RuntimeError("GPU is required to run this example!")
+
+    # Skip unsupported testcase
+    if not Sm100BlockScaledContiguousGroupedGemmFinalizeFusionKernel.can_implement(
+        ab_dtype,
+        sf_dtype,
+        sf_vec_size,
