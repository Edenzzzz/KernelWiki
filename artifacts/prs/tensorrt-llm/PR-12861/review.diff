+    del mm_item_types, mm_special_offsets_cu_seqlen, mm_special_offsets
+    batch_size, seq_len = input_ids.shape[:2]
+    return torch.empty(batch_size, 1, seq_len, seq_len, dtype=torch.bool, device=input_ids.device)
+
