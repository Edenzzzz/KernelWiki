+def gemm_drelu_ref(A: Tensor, B: Tensor, preact: Tensor) -> (Tensor, Tensor):
+    # A: (M, K), B: (K, N), preact: (M, N)
+    dout = torch.mm(A, B)
+    dx = torch.where(preact > 0, dout, torch.zeros_like(dout))
+    postact = torch.clamp(preact, min=0.0)
+    return dx, postact
+
