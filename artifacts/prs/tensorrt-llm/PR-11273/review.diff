+        cu,
+        chunk_indices,
+        chunk_offsets,
+        num_seqs=num_seqs,
+        chunk_size=chunk_size,
+        N=N,
+        BLOCK_SIZE=BLOCK_SIZE,
+    )
+
+    return chunk_indices, chunk_offsets
+
