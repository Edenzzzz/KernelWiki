+                        remaining_k,
+                        local_histogram,
+                        prefix_buf,
+                        s_scalars,
+                        s_warp_sums,
+                        state_base_ptr,
+                        state_row,
+                        cta_in_group,
+                        barrier_phase,
+                        ctas_per_group,
+                        num_threads,
+                        tidx,
