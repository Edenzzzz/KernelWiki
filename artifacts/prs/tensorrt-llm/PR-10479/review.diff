+    weight_per_expert = n // expert_count
+
+    print("Running Sm100 Persistent Dense BlockScaled GEMM with SwiGLU fusion test with:")
+    print(f"mnkl: {mnkl}")
+    print(f"AB dtype: {ab_dtype}, SF dtype: {sf_dtype}, SF Vec size: {sf_vec_size}")
