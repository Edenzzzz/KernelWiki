      "gists_url": "https://api.github.com/users/Harry-Chen/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/Harry-Chen/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/Harry-Chen/subscriptions",
      "organizations_url": "https://api.github.com/users/Harry-Chen/orgs",
      "repos_url": "https://api.github.com/users/Harry-Chen/repos",
      "events_url": "https://api.github.com/users/Harry-Chen/events{/privacy}",
