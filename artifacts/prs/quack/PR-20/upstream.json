    "title": "add reduction options to Quack Cross Entropy for PyTorch drop-in usage",
    "user": {
      "login": "lessw2020",
      "id": 46302957,
      "node_id": "MDQ6VXNlcjQ2MzAyOTU3",
      "avatar_url": "https://avatars.githubusercontent.com/u/46302957?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/lessw2020",
      "html_url": "https://github.com/lessw2020",
      "followers_url": "https://api.github.com/users/lessw2020/followers",
      "following_url": "https://api.github.com/users/lessw2020/following{/other_user}",
      "gists_url": "https://api.github.com/users/lessw2020/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/lessw2020/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/lessw2020/subscriptions",
      "organizations_url": "https://api.github.com/users/lessw2020/orgs",
      "repos_url": "https://api.github.com/users/lessw2020/repos",
      "events_url": "https://api.github.com/users/lessw2020/events{/privacy}",
