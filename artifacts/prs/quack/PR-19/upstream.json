      "gists_url": "https://api.github.com/users/lessw2020/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/lessw2020/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/lessw2020/subscriptions",
      "organizations_url": "https://api.github.com/users/lessw2020/orgs",
