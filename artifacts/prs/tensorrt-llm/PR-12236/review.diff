+                            state_base_ptr + cutlass.Int32(_ARRIVAL_COUNTER), cutlass.Int32(1)
+                        )
+                    barrier_phase = barrier_phase + 1
+                    barrier_inter_cta(
+                        state_base_ptr + cutlass.Int32(_ARRIVAL_COUNTER),
+                        barrier_phase * ctas_per_group,
+                        tidx,
+                    )
